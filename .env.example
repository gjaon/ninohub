# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ninohub

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# PayStack Configuration
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_MODE=test
# For production: sk_live_xxxxxxxxxxxxxxxxxxxxx

# Server Configuration
PORT=5000
NODE_ENV=development

# Client URLs (for CORS)
CLIENT_ORIGIN=http://localhost:3000

# Optional: Additional origins (comma-separated)
# CLIENT_ORIGIN=http://localhost:3000,https://www.ninohub.com

# Marketplace Feature Flags
MARKETPLACE_PUBLIC_API_ENABLED=false
MARKETPLACE_WEBHOOKS_ENABLED=false
MARKETPLACE_INTERNAL_UI_ENABLED=false

# Marketplace Secrets
PUBLIC_PARTNER_JWT_SECRET=replace_with_partner_jwt_secret
MARKETPLACE_SECRET_ENCRYPTION_KEY=replace_with_32_plus_characters

# Marketplace Origin Allowlists (comma-separated)
MARKETPLACE_FRONTEND_ORIGINS=http://localhost:3000,https://www.ninohub.com
MARKETPLACE_PARTNER_ALLOWED_ORIGINS=http://localhost:3000,https://www.ninohub.com

# Provider Connectivity
MARKETPLACE_PROVIDER_BASE_URL=https://provider.example.com
# Alias for partner keyId (used for /auth/token signed exchange)
MARKETPLACE_PROVIDER_API_KEY=mkp_key_id
# Alias for partner key secret (used for /auth/token signed exchange)
MARKETPLACE_PROVIDER_API_SECRET=mkp_key_secret
# Optional legacy/static bearer token mode (only use if your provider explicitly issues long-lived bearer tokens)
# MARKETPLACE_PROVIDER_BEARER_TOKEN=provider_bearer_token
MARKETPLACE_PROVIDER_INVENTORY_PATH=/inventory
# Optional comma-separated fallback list (overrides single path)
# MARKETPLACE_PROVIDER_INVENTORY_PATHS=/inventory,/api/inventory,/products,/api/products
MARKETPLACE_PROVIDER_WEBHOOK_SECRET=provider_webhook_secret

# Centralized Integration Endpoint Control
# Dev example: http://localhost:4000
MARKETPLACE_INTEGRATION_BASE_URL=http://localhost:4000
MARKETPLACE_INTEGRATION_BASE_PATH=/api/public/v1/marketplace
MARKETPLACE_INTEGRATION_LISTINGS_PATH=/listings
MARKETPLACE_INTEGRATION_HOLDS_PATH=/holds
MARKETPLACE_INTEGRATION_ORDERS_PATH=/orders
MARKETPLACE_INTEGRATION_AUTH_TOKEN_PATH=/auth/token
MARKETPLACE_INTEGRATION_AUTH_REFRESH_PATH=/auth/token/refresh

# Partner auth credentials for signed token issuance
MARKETPLACE_INTEGRATION_KEY_ID=mkp_key_id
MARKETPLACE_INTEGRATION_KEY_SECRET=mkp_key_secret
# Optional bootstrap refresh token (used before first token issuance if present)
# MARKETPLACE_INTEGRATION_REFRESH_TOKEN=refresh_token_here
# Proactive refresh buffer in milliseconds (default 120000 = 2 minutes)
# MARKETPLACE_INTEGRATION_AUTH_CLOCK_SKEW_MS=120000

# Checkout + Sync
MARKETPLACE_CHECKOUT_RETURN_URL=http://localhost:3000/checkout
MARKETPLACE_WEBHOOK_RETRY_MAX_ATTEMPTS=6
MARKETPLACE_WEBHOOK_RETRY_BASE_DELAY_MS=15000

# Provider Webhook Auto-Registration
# Enable Nino to create/update the SellSquare webhook endpoint automatically
MARKETPLACE_PROVIDER_WEBHOOK_REGISTRATION_ENABLED=false
# Public base URL that SellSquare can call (must be reachable from SellSquare)
# Example: https://api.ninohub.com
MARKETPLACE_WEBHOOK_PUBLIC_BASE_URL=http://localhost:5000
# Inbound webhook path on Nino
MARKETPLACE_WEBHOOK_INBOUND_PATH=/api/webhooks/marketplace
# Provider API path for webhook endpoint management
MARKETPLACE_INTEGRATION_WEBHOOK_ENDPOINTS_PATH=/webhooks/endpoints
# Rotate shared webhook secret every N days (applies when auto-registration is enabled)
MARKETPLACE_PROVIDER_WEBHOOK_SECRET_ROTATE_DAYS=30
